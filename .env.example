# App
APP_ENV=local
APP_NAME=stock_ai_platform
APP_HOST=127.0.0.1
APP_PORT=8000
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_TO_FILE=false
TIMEZONE=Asia/Seoul

# Database Setup (기본 로컬 테스트용 SQLite. Docker에서는 PostgreSQL로 오버라이드)
DATABASE_URL=sqlite:///./stock_ai.db
SQLITE_DATABASE_URL=sqlite:///./stock_ai.db

# Korea Investment & Securities API (KIS)
KIS_APP_KEY=mock_app_key_here
KIS_APP_SECRET=mock_app_secret_here
KIS_ACCOUNT_NO=12345678-01
KIS_ACCOUNT_PRODUCT_CODE=01
KIS_USE_PAPER=true
KIS_TIMEOUT_SECONDS=10

# Market data collection
COLLECT_MARKET=KOSPI
MARKET_CAP_LIMIT=500
MARKET_CAP_UNIVERSE_NAME=MARKET_CAP_TOP_500
DAILY_PRICE_LOOKBACK_DAYS=1
DAILY_PRICE_BATCH_SIZE=100

# Technical indicator calculation
INDICATOR_UNIVERSE_NAME=MARKET_CAP_TOP_500
INDICATOR_LOOKBACK_DAYS=250
INDICATOR_BATCH_SIZE=100

# Telegram Notification
TELEGRAM_BOT_TOKEN=mock_bot_token_here
TELEGRAM_CHAT_ID=123456789
TELEGRAM_ENABLED=false
TELEGRAM_API_BASE_URL=https://api.telegram.org
TELEGRAM_TIMEOUT_SECONDS=10

# Scheduler
SCHEDULER_ENABLED=false

# v0.1 safety flags (keep disabled)
FEATURE_REAL_ORDER_EXECUTION=false
FEATURE_FULL_AUTO=false
FEATURE_PAPER_TRADING=false
FEATURE_BACKTEST=false
FEATURE_CUSTOM_AI_TRAINING=false

# ===========================================================================
# v0.15 / v1.0 Safety Gates (모두 paranoid default — 코드에 박혀 있음)
# ===========================================================================
#
# 본 .env 에 아래 5개를 적지 않아도 Settings 가 코드 default 로 fallback 합니다.
# 즉 .env 에 없으면 = 안전 모드. 실거래는 구조적으로 발생할 수 없습니다.
#
# `_as_strict_bool` helper 정책: 정확한 토큰 (true/false/1/0/on/off/yes/no) 만
# 인식되며, typo (예: KILL_SWITCH_ENABLED=maybe) 시에는 default 유지.
#
# 실 KIS 주문을 활성화하려면 다음을 모두 따라야 합니다:
#   1) RUNBOOK_REAL_TRADING.md §1 의 9 항목 전제 조건 통과 (운영자 체크리스트)
#   2) §2 의 5 단계 .env 활성화 절차 (단계별 dry-run 검증 포함)
#   3) 사용자가 화면 (/approvals) 에서 명시 승인
# 위 3 단계를 모두 지나야만 1 후보 = 1 승인 = 1 실주문 원칙으로 진입 가능합니다.

# --- v0.15 Approval Trading Safety Layer (paranoid defaults) ---
# KILL_SWITCH_ENABLED=true        # default: true  (paranoid master block)
# TRADING_SAFETY_ENABLED=false    # default: false (Approval API 자체 503 차단)
# APPROVAL_REQUIRED=true          # default: true  (자동 승인 0건)

# --- v0.16 Real Order Integration (paranoid defaults) ---
# REAL_TRADING_ENABLED=false      # default: false (실거래 master switch)
# KIS_ORDER_ENABLED=false         # default: false (KIS 주문 API 게이트)
# REAL_ORDER_DRY_RUN=true         # default: true  (모든 실행은 dry-run)

# --- v0.16 Real Order 한도 (소액 권장 — 변경 시 RUNBOOK §1.10 검토) ---
# MAX_REAL_ORDER_AMOUNT=100000          # default: 100,000 KRW (회당)
# MAX_REAL_DAILY_ORDER_AMOUNT=1000000   # default: 1,000,000 KRW (일일 누적)
# 권장 cap: MAX_REAL_ORDER_AMOUNT ≤ 1,000,000 / MAX_REAL_DAILY_ORDER_AMOUNT ≤ 10,000,000
# 초과 시 validate_real_trading_operating_limits() 에서 advisory 반환.

# --- v1.0 KIS Order Transport (Phase B, 실 transport 사용 시에만 의미) ---
# KIS_ORDER_BASE_URL=https://openapivts.koreainvestment.com:29443  # default: paper VTS
# KIS_ORDER_PLACE_TIMEOUT_S=5.0
# KIS_ORDER_QUERY_TIMEOUT_S=10.0
# KIS_ORDER_CANCEL_TIMEOUT_S=5.0

# --- 기타 default-OFF (자동 호출 0건 보장) ---
# DART_ENABLED=false
# RSS_NEWS_ENABLED=false
# PROVIDER_DATA_INGESTION_ENABLED=false
# PROVIDER_SCORE_POLICY_ENABLED=false
# PROMETHEUS_ENABLED=false
# PAPER_TRADING_ENABLED=false
# AUTH_ENABLED=false              # 운영 진입 시 true 권장 (RUNBOOK §1 항목 6)
