# App
APP_ENV=local
APP_NAME=stock_ai_platform
APP_HOST=127.0.0.1
APP_PORT=8000
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_TO_FILE=false
TIMEZONE=Asia/Seoul

# Database Setup (기본 로컬 테스트용 SQLite. Docker에서는 PostgreSQL로 오버라이드)
DATABASE_URL=sqlite:///./stock_ai.db
SQLITE_DATABASE_URL=sqlite:///./stock_ai.db

# Korea Investment & Securities API (KIS)
KIS_APP_KEY=mock_app_key_here
KIS_APP_SECRET=mock_app_secret_here
KIS_ACCOUNT_NO=12345678-01
KIS_ACCOUNT_PRODUCT_CODE=01
KIS_USE_PAPER=true
KIS_TIMEOUT_SECONDS=10

# Market data collection
COLLECT_MARKET=KOSPI
MARKET_CAP_LIMIT=500
MARKET_CAP_UNIVERSE_NAME=MARKET_CAP_TOP_500
DAILY_PRICE_LOOKBACK_DAYS=1
DAILY_PRICE_BATCH_SIZE=100

# Technical indicator calculation
INDICATOR_UNIVERSE_NAME=MARKET_CAP_TOP_500
INDICATOR_LOOKBACK_DAYS=250
INDICATOR_BATCH_SIZE=100

# Telegram Notification
TELEGRAM_BOT_TOKEN=mock_bot_token_here
TELEGRAM_CHAT_ID=123456789
TELEGRAM_ENABLED=false
TELEGRAM_API_BASE_URL=https://api.telegram.org
TELEGRAM_TIMEOUT_SECONDS=10

# Scheduler
SCHEDULER_ENABLED=false

# v0.1 safety flags (keep disabled)
FEATURE_REAL_ORDER_EXECUTION=false
FEATURE_FULL_AUTO=false
FEATURE_PAPER_TRADING=false
FEATURE_BACKTEST=false
FEATURE_CUSTOM_AI_TRAINING=false
