# Application
APP_ENV=local
APP_NAME=stock_ai_platform
APP_HOST=127.0.0.1
APP_PORT=8000
LOG_LEVEL=INFO
TIMEZONE=Asia/Seoul

# Database
DATABASE_URL=postgresql+psycopg://stock_ai:stock_ai_password@localhost:5432/stock_ai
SQLITE_DATABASE_URL=sqlite:///./stock_ai.db

# Korea Investment & Securities API
KIS_APP_KEY=your_kis_app_key_here
KIS_APP_SECRET=your_kis_app_secret_here
KIS_ACCOUNT_NO=your_account_no_here
KIS_ACCOUNT_PRODUCT_CODE=01
KIS_BASE_URL=https://openapi.koreainvestment.com:9443
KIS_PAPER_BASE_URL=https://openapivts.koreainvestment.com:29443
KIS_USE_PAPER=true
KIS_TIMEOUT_SECONDS=10

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
TELEGRAM_ENABLED=false

# AI Provider
AI_PROVIDER=dummy
OPENAI_API_KEY=your_openai_api_key_here
LOCAL_LLM_BASE_URL=http://localhost:11434
LOCAL_LLM_MODEL=qwen-or-llama-model-name

# Scheduler
SCHEDULER_ENABLED=true
JOB_COLLECT_CLOSE_DATA_TIME=18:00
JOB_RECOMMENDATION_REPORT_TIME=06:00
JOB_PRE_MARKET_CHECK_TIME=08:30
JOB_POST_MARKET_CHECK_TIME=16:30

# Security
SECRET_KEY=change_me
MASK_SECRETS_IN_LOGS=true

# Feature Flags
FEATURE_REAL_ORDER_EXECUTION=false
FEATURE_FULL_AUTO=false
FEATURE_PAPER_TRADING=false
FEATURE_BACKTEST=false
FEATURE_CUSTOM_AI_TRAINING=false
